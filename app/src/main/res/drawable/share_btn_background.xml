<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradient for two-color effect -->
    <gradient
        android:startColor="#E357A0D3"
    android:endColor="#001f3f"
    android:angle="270" />

    <!-- Rounded corners -->
    <corners android:radius="16dp" />

    <!-- Padding -->
    <padding
        android:left="-10dp"
        android:top="-10dp"
        android:right="-10dp"
        android:bottom="-10dp" />
</shape>
