<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="52dp"
    android:paddingBottom="24dp">

    <!-- ── TOP BAR ────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="40dp"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="10dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CampusKey"
            android:textColor="#E6EDF3"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_surface_card"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="v2.0"
            android:textColor="#8B949E"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- ── STATUS SECTION ─────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Status ring + icon -->
        <FrameLayout
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginBottom="24dp">

            <!-- Ring -->
            <View
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:background="@drawable/bg_icon_circle" />

            <!-- App icon -->
            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <!-- Status text -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Initializing..."
            android:textColor="#E6EDF3"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="200dp"
            android:layout_height="3dp"
            android:indeterminate="true"
            android:indeterminateTint="#6366F1"
            android:progressBackgroundTint="#21262D"
            android:visibility="invisible" />
    </LinearLayout>

    <!-- ── DEVELOPER CARD ─────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_surface_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Avatar -->
        <androidx.cardview.widget.CardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#21262D">
            <ImageView
                android:id="@+id/imgDev"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/man" />
        </androidx.cardview.widget.CardView>

        <!-- Name & handle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvDevName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Utkarsh Sahu"
                android:textColor="#E6EDF3"
                android:textSize="15sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developer"
                android:textColor="#8B949E"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Social icon buttons -->
        <ImageView
            android:id="@+id/btnInstagram"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_icon_btn"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/instagram" />

        <ImageView
            android:id="@+id/btnLinkedIn"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_icon_btn"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/linkedin" />

        <ImageView
            android:id="@+id/btnMail"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_icon_btn"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/gmail" />
    </LinearLayout>

    <!-- ── SHARE BUTTON ───────────────────────────────────── -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/share"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/btn_indigo"
        android:text="Share CampusKey"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:elevation="0dp"
        android:stateListAnimator="@null" />

</LinearLayout>