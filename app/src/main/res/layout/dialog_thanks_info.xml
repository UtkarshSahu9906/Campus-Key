<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_surface_card"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Special Thanks Info"
        android:textColor="#E6EDF3"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This leaderboard celebrates our community members based on their total successful Wi-Fi connections using CampusKey."
        android:textColor="#8B949E"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="HOW TO JOIN"
        android:textColor="#D29922"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.2" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="1. Tap the button below to open the Info page.\n2. Click on '+ Join Leaderboard'.\n3. Enter your display name and Instagram."
        android:textColor="#E6EDF3"
        android:textSize="13sp"
        android:lineSpacingExtra="6dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnGoToInfo"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/btn_indigo"
        android:text="Join the Leaderboard"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btnDismissDialog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:text="Dismiss"
        android:textColor="#8B949E"
        android:textSize="14sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

</LinearLayout>
