<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#161B22">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rate CampusKey"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#E6EDF3"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your rating will be visible on the Community Wall."
        android:textSize="14sp"
        android:textColor="#8B949E"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/etFeedbackDisplayName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Your Display Name (e.g. CampusHero)"
        android:padding="16dp"
        android:background="@drawable/bg_surface_card"
        android:textColor="#E6EDF3"
        android:textColorHint="#484F58"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">
        
        <TextView android:id="@+id/star1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="32sp" android:layout_margin="4dp"/>
        <TextView android:id="@+id/star2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="32sp" android:layout_margin="4dp"/>
        <TextView android:id="@+id/star3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="32sp" android:layout_margin="4dp"/>
        <TextView android:id="@+id/star4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="32sp" android:layout_margin="4dp"/>
        <TextView android:id="@+id/star5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="32sp" android:layout_margin="4dp"/>
    </LinearLayout>

    <EditText
        android:id="@+id/etFeedbackComment"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="Tell us what you think..."
        android:gravity="top"
        android:padding="16dp"
        android:background="@drawable/bg_surface_card"
        android:textColor="#E6EDF3"
        android:textColorHint="#484F58"
        android:textSize="15sp"
        android:layout_marginBottom="24dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSubmitFeedback"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Share with Community"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_indigo"
        android:textStyle="bold" />

</LinearLayout>
