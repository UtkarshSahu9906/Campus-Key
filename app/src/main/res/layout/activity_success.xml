<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">


    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/doneAnimation"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:visibility="gone"
        app:lottie_autoPlay="true"
        app:lottie_loop="false"
        app:lottie_rawRes="@raw/done_task" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/networkErrorAnimation"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:visibility="gone"
        app:lottie_autoPlay="true"
        app:lottie_loop="false"
        app:lottie_rawRes="@raw/network_error" />


    <TextView
        android:id="@+id/connectionStatusMessage"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/allerta_stencil"
        android:gravity="center"
        android:text="Successfully Logged In!"
        android:textColor="@color/white"
        android:textSize="24sp" />

    <TextView
        android:id="@+id/textViewLinks"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Follow us on:"
        android:textColor="@color/white"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageViewInstagram"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="18dp"
            android:contentDescription="Instagram"
            android:src="@drawable/instagram" />

        <ImageView
            android:id="@+id/imageViewLinkedIn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:contentDescription="LinkedIn"
            android:src="@drawable/linkedin" />
    </LinearLayout>

</LinearLayout>
