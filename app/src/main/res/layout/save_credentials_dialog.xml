<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/background_dark"
    android:elevation="8dp">

    <!-- Welcome Message with Custom Font -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome to Campus Key!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_bold"
        android:layout_marginBottom="8dp"/>

    <!-- Modern Message with Custom Font -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Effortlessly connect to Kalinga University Wi-Fi with just a tap. Campus Key auto-fills your username and password, making login seamless and hassle-free."
        android:textSize="16sp"
        android:gravity="center"
        android:textColor="@color/gray_light"
        android:fontFamily="@font/poppins"
        android:layout_marginBottom="24dp"/>

    <!-- Credentials Heading with Custom Font -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Store College Credentials"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_bold"/>

    <EditText
        android:id="@+id/editTextUsername"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Username"
        android:inputType="textPersonName"
        android:padding="12dp"
        android:background="@drawable/edittext_background_dark"
        android:textColor="@color/white"
        android:textColorHint="@color/gray_light"
        android:layout_marginTop="16dp" />

    <EditText
        android:id="@+id/editTextPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Password"
        android:inputType="textPassword"
        android:padding="12dp"
        android:background="@drawable/edittext_background_dark"
        android:textColor="@color/white"
        android:textColorHint="@color/gray_light"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/buttonLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SAVE"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/colorAccent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/textViewMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@android:color/holo_red_light"
        android:gravity="center"
        android:layout_marginTop="8dp" />
</LinearLayout>
