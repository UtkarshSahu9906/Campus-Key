<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#161B22">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="College Credentials"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#E6EDF3"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your credentials are saved locally to enable automatic Wi-Fi login."
        android:textSize="14sp"
        android:textColor="#8B949E"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/editTextUsername"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="University ID / Username"
        android:inputType="text"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/bg_surface_card"
        android:textColor="#E6EDF3"
        android:textColorHint="#484F58"
        android:textSize="15sp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/editTextPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Wi-Fi Password"
        android:inputType="textPassword"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/bg_surface_card"
        android:textColor="#E6EDF3"
        android:textColorHint="#484F58"
        android:textSize="15sp"
        android:layout_marginBottom="20dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/buttonLogin"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Save Credentials"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_indigo"
        android:textStyle="bold"
        android:elevation="0dp"
        android:stateListAnimator="@null" />

    <TextView
        android:id="@+id/textViewMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#F85149"
        android:gravity="center"
        android:textSize="13sp"
        android:layout_marginTop="12dp" />
</LinearLayout>
